<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="16dp">

        <!-- 标题 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btn_back"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="◀"
                android:textSize="16sp"
                android:textColor="@color/accent"
                android:background="@drawable/input_bg" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="SERVER CONFIG"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/accent"
                android:letterSpacing="0.08" />
        </LinearLayout>

        <!-- 服务器名称 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Server Name"
            style="@style/GlassLabel"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/edit_server_name"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:hint="e.g. R730 HomeLab"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:singleLine="true"
            android:layout_marginBottom="14dp" />

        <!-- IP 地址 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="iDRAC IP"
            style="@style/GlassLabel"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/edit_ip"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:hint="192.168.1.100"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:singleLine="true"
            android:layout_marginBottom="14dp" />

        <!-- 用户名 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Username"
            style="@style/GlassLabel"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/edit_user"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:hint="root"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:singleLine="true"
            android:layout_marginBottom="14dp" />

        <!-- 密码 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Password"
            style="@style/GlassLabel"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/edit_pass"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:hint="password"
            android:inputType="textPassword"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:singleLine="true"
            android:layout_marginBottom="14dp" />

        <!-- 连接模式 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mode"
            style="@style/GlassLabel"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinner_mode"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:layout_marginBottom="14dp" />

        <!-- 端口 (并排) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SSH Port"
                    style="@style/GlassLabel"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/edit_ssh_port"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:hint="22"
                    android:inputType="number"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:background="@drawable/input_bg"
                    android:padding="12dp"
                    android:singleLine="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="HTTPS Port"
                    style="@style/GlassLabel"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/edit_https_port"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:hint="443"
                    android:inputType="number"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:background="@drawable/input_bg"
                    android:padding="12dp"
                    android:singleLine="true" />
            </LinearLayout>
        </LinearLayout>

        <!-- 保存/删除按钮 -->
        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="SAVE CONFIG"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/text_on_primary"
            android:background="@drawable/btn_save"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_delete"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:text="DELETE SERVER"
            android:textSize="13sp"
            android:textColor="@color/red"
            android:background="@drawable/input_bg" />

        <View android:layout_width="match_parent" android:layout_height="24dp" />
    </LinearLayout>
</ScrollView>
